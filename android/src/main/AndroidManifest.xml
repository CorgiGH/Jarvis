<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
          xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- Phase 3.1 (council 1778184643): WorkManager polls /api/signals
         and posts a system Notification per new ProactiveSignal. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Phone activity logger — reads which app is foregrounded so server-
         side drift detection sees phone usage same as PC. Special permission
         user grants via Settings > Apps > Special access > Usage access. -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS"
                     tools:ignore="ProtectedPermissions" />
    <!-- 2026-05-08: BackgroundPollService promotes the /api/signals poll to
         a foreground service so notifications fire reliably when app is
         closed (Android 12+ throttles WorkManager periodic in fully-
         backgrounded apps). FOREGROUND_SERVICE_DATA_SYNC is the explicit
         type-permission Android 14+ requires alongside foregroundServiceType. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- Required so the system speech recognizer picker dialog can find a STT
         service on Android 11+ scoped package visibility. -->
    <queries>
        <intent>
            <action android:name="android.speech.RecognitionService" />
        </intent>
        <intent>
            <action android:name="android.intent.action.TTS_SERVICE" />
        </intent>
    </queries>

    <application
        android:label="@string/app_name"
        android:theme="@android:style/Theme.Material.Light.NoActionBar"
        android:networkSecurityConfig="@xml/network_security_config"
        android:supportsRtl="true"
        android:allowBackup="false">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@android:style/Theme.Material.Light.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <!-- R3: signal-action receiver for Pin / Dismiss notification buttons. -->
        <receiver
            android:name=".SignalActionReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="io.victor.jarvis.action.SIGNAL_ACK" />
            </intent-filter>
        </receiver>
        <!-- 2026-05-08: foreground service for reliable background polling
             when the app is closed. Type "dataSync" matches the periodic
             /api/signals + /api/focus pull pattern. -->
        <service
            android:name=".BackgroundPollService"
            android:foregroundServiceType="dataSync"
            android:exported="false" />
    </application>
</manifest>
