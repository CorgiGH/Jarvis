# Provider selection. Defaults to claude-max (uses local 'claude' CLI under
# your Claude Max subscription; no API charges).
# Options: claude-max | openrouter | anthropic
JARVIS_LLM=claude-max

# Optional model override for claude-max (e.g. sonnet, opus, claude-sonnet-4-6).
# JARVIS_CLAUDE_MODEL=sonnet

# Required when JARVIS_LLM=openrouter. Used by EmbeddingsClient regardless of
# the chat provider, since Anthropic does not expose embeddings.
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Required when JARVIS_LLM=anthropic. Currently the AnthropicLlm class is a
# stub; flip to this provider only after filling it in.
# ANTHROPIC_API_KEY=sk-ant-...
