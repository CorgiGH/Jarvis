# Required. Bearer token gating the web server. Generate any 32+ random chars,
# e.g. `openssl rand -hex 32` or pwgen 64. Must match what the phone APK
# settings field is set to.
JARVIS_AUTH_TOKEN=replace-with-random-32-char-or-longer-string

# Provider selection.
# Options:
#   claude-max  - subprocess `claude --print`; uses Claude Max subscription
#   copilot     - subprocess `copilot -p`; uses GitHub Copilot subscription
#   anthropic   - direct Anthropic API (currently stub; do not use yet)
#   relay       - HTTP POST to a Tailscale-reachable PC running
#                 tools/pc-relay-server.py (which wraps `claude --print`)
#   fallback    - try JARVIS_PRIMARY_LLM first; on failure use
#                 JARVIS_FALLBACK_LLM. Defaults: relay primary, copilot
#                 fallback. Either slot may be any non-fallback provider.
# Default is claude-max. Use copilot if you have not run `claude login` yet.
JARVIS_LLM=claude-max

# Optional model override for claude-max (e.g. sonnet, opus, claude-sonnet-4-6).
# JARVIS_CLAUDE_MODEL=sonnet

# Optional model override for copilot (e.g. claude-sonnet-4.5, gpt-5).
# JARVIS_COPILOT_MODEL=claude-sonnet-4.5

# Required when JARVIS_LLM=fallback. Set to any non-fallback provider name.
# JARVIS_PRIMARY_LLM=relay
# JARVIS_FALLBACK_LLM=copilot

# Required when JARVIS_LLM=relay (or when relay is the primary/fallback in
# fallback mode). RelayLlm POSTs JSON to JARVIS_RELAY_URL/complete with a
# bearer-auth header. Generate the token with `openssl rand -hex 32` and
# set the SAME value in the PC's tools/pc-relay-server.py environment.
# JARVIS_RELAY_URL=http://100.100.0.5:9999
# JARVIS_RELAY_TOKEN=replace-with-32-char-hex
# JARVIS_RELAY_CONNECT_S=5
# JARVIS_RELAY_READ_S=120

# OPTIONAL. Only needed if you want semantic memory (cosine search over wiki).
# Embeddings are computed via OpenRouter's text-embedding-3-small (~$0.02/1M
# tokens). If unset, jarvis falls back to last-N retrieval — chat still works,
# just without similarity-based wiki recall.
# OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Required when JARVIS_LLM=anthropic. Currently the AnthropicLlm class is a
# stub; flip to this provider only after filling it in.
# ANTHROPIC_API_KEY=sk-ant-...

# OPTIONAL. Tutor-surface chat path. When set to "openrouter", the tutor
# (https://corgflix.duckdns.org/tutor/) sends chat through OpenRouterChatLlm
# with tool_use enabled (search_archival, query_graph, wiki_*, etc.). When
# unset, the tutor uses the legacy ChatTools path (no tools). Requires
# OPENROUTER_API_KEY to also be set.
# JARVIS_LLM_TUTOR=openrouter

# OPTIONAL. Override the OpenRouter chat model used by both the legacy
# `JARVIS_LLM=openrouter` provider AND the tutor surface. Defaults to
# meta-llama/llama-3.3-70b-instruct:free. Free-tier models are subject to
# upstream provider rate limits (Venice, Together, etc.) and OpenRouter
# may pull them at any time — see JARVIS_OPENROUTER_FALLBACK_MODELS below.
# JARVIS_OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# OPTIONAL. Comma-separated OpenRouter model IDs used as a server-side
# fallback chain when the primary is pulled or returns 404/410 at the
# OpenRouter edge. The chat-completions request body sends
# `models: [primary, ...fallbacks]` so OpenRouter routes around dead
# models in a single round-trip. Transient 429s (rate-limit) are NOT
# routed past — they trigger a single client-side retry honoring the
# Retry-After header (only if ≤ 5s); longer waits propagate so the
# caller's degraded chat path serves the turn. Validate model IDs at
# https://openrouter.ai/models before adding — an invalid ID rejects
# the entire request with HTTP 400.
# JARVIS_OPENROUTER_FALLBACK_MODELS=mistralai/mistral-small-3.1-24b-instruct:free,qwen/qwen-2.5-72b-instruct:free

# Phase 5.3: per-subject course-page scraper URLs. User fills these
# when known. Empty/unset → ManualEntryScraper takes over (returns
# nothing). Phase 6 wires real scrapers behind these env vars.
JARVIS_COURSE_PAGE_PA=
JARVIS_COURSE_PAGE_PS=
JARVIS_COURSE_PAGE_POO=
JARVIS_COURSE_PAGE_ALO=
JARVIS_COURSE_PAGE_SO=
JARVIS_COURSE_PAGE_RC=
