{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File tools/memory-verify.ps1"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File tools/inject-constraints.ps1"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File tools/context-budget-hook.ps1",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "kotlin-lsp@claude-plugins-official": true
  }
}
